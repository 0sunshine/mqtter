MQTTER_DATABASE_URL=postgres://postgres:change-me@127.0.0.1:5432/postgres?sslmode=disable
MQTTER_HTTP_ADDR=:8080
MQTTER_MQTT_ADDR=:1883
MQTTER_BROKER_STORE_PATH=data/broker-pebble
MQTTER_INGEST_TIMEOUT=2s
MQTTER_SCHEDULER_INTERVAL=10s
MQTTER_MAX_PAYLOAD_BYTES=262144
MQTTER_SESSION_COOKIE=mqtter_session
MQTTER_SESSION_TTL=24h
MQTTER_BOOTSTRAP_ADMIN_USERNAME=admin
MQTTER_BOOTSTRAP_ADMIN_PASSWORD=change-me
